<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Congratulations — Become Primed</title>

<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

<style>

  :root {

    --red: 
#C0392B;

    --red-light: 
#E74C3C;

    --dark: 
#0F0E15;

    --dark2: 
#18161F;

    --dark3: 
#22202C;

    --gold: 
#D4A843;

    --white: 
#FFFFFF;

    --gray: 
#A0A0A0;

    --gray-light: 
#D0CED8;

    --border: rgba(255,255,255,0.08);

  }

  , ::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {

    background: var(--dark);

    color: var(--white);

    font-family: 'DM Sans', sans-serif;

    font-size: 16px;

    line-height: 1.6;

    overflow-x: hidden;

  }

  /* ── NOISE TEXTURE OVERLAY ── */

  body::before {

    content: '';

    position: fixed;

    inset: 0;

    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");

    background-size: 128px 128px;

    pointer-events: none;

    z-index: 0;

    opacity: 0.6;

  }

  /* ── HERO ── */

  .hero {

    position: relative;

    min-height: 100vh;

    display: flex;

    flex-direction: column;

    align-items: center;

    justify-content: center;

    text-align: center;

    padding: 60px 24px 80px;

    overflow: hidden;

  }

  .hero::before {

    content: '';

    position: absolute;

    top: -200px; left: 50%; transform: translateX(-50%);

    width: 900px; height: 600px;

    background: radial-gradient(ellipse, rgba(192,57,43,0.18) 0%, transparent 70%);

    pointer-events: none;

  }

  .hero::after {

    content: '';

    position: absolute;

    bottom: 0; left: 0; right: 0;

    height: 1px;

    background: linear-gradient(90deg, transparent, var(--border), var(--red), var(--border), transparent);

  }

  .trophy-ring {

    width: 100px; height: 100px;

    border-radius: 50%;

    border: 1.5px solid var(--red);

    display: flex; align-items: center; justify-content: center;

    margin: 0 auto 32px;

    position: relative;

    animation: ring-pulse 3s ease-in-out infinite;

  }

  .trophy-ring::before {

    content: '';

    position: absolute; inset: -8px;

    border-radius: 50%;

    border: 1px solid rgba(192,57,43,0.25);

    animation: ring-pulse 3s ease-in-out 0.5s infinite;

  }

  @keyframes ring-pulse {

    0%, 100% { opacity: 1; transform: scale(1); }

    50% { opacity: 0.7; transform: scale(1.04); }

  }

  .trophy-emoji { font-size: 42px; line-height: 1; }

  .hero-eyebrow {

    font-family: 'DM Sans', sans-serif;

    font-size: 11px;

    font-weight: 600;

    letter-spacing: 0.3em;

    text-transform: uppercase;

    color: var(--red);

    margin-bottom: 20px;

  }

  .hero-title {

    font-family: 'Bebas Neue', sans-serif;

    font-size: clamp(72px, 14vw, 130px);

    line-height: 0.9;

    letter-spacing: 0.02em;

    margin-bottom: 8px;

  }

  .hero-title .line-gold { color: var(--gold); }

  .hero-subtitle {

    font-family: 'DM Serif Display', Georgia, serif;

    font-style: italic;

    font-size: clamp(18px, 3vw, 26px);

    color: var(--gray-light);

    margin-bottom: 28px;

    font-weight: 400;

  }

  .hero-desc {

    max-width: 560px;

    font-size: 16px;

    color: var(--gray);

    line-height: 1.75;

    margin-bottom: 48px;

  }

  .scroll-cta {

    display: flex; flex-direction: column; align-items: center; gap: 8px;

    color: var(--gray);

    font-size: 12px;

    letter-spacing: 0.15em;

    text-transform: uppercase;

    animation: bounce 2s ease-in-out infinite;

    cursor: pointer;

  }

  .scroll-cta svg { opacity: 0.5; }

  @keyframes bounce {

    0%, 100% { transform: translateY(0); }

    50% { transform: translateY(6px); }

  }

  /* ── PRIZE BANNER ── */

  .prize-banner {

    background: var(--red);

    padding: 16px 24px;

    text-align: center;

    font-family: 'Bebas Neue', sans-serif;

    font-size: clamp(14px, 3vw, 18px);

    letter-spacing: 0.2em;

    position: relative;

    z-index: 1;

  }

  /* ── SECTIONS ── */

  .section {

    position: relative;

    z-index: 1;

    max-width: 840px;

    margin: 0 auto;

    padding: 80px 24px;

  }

  .section + .section {

    border-top: 1px solid var(--border);

  }

  .section-number {

    font-family: 'Bebas Neue', sans-serif;

    font-size: 72px;

    color: rgba(255,255,255,0.04);

    line-height: 1;

    margin-bottom: -20px;

    pointer-events: none;

  }

  .section-label {

    font-size: 11px;

    font-weight: 600;

    letter-spacing: 0.28em;

    text-transform: uppercase;

    color: var(--red);

    margin-bottom: 12px;

  }

  .section-title {

    font-family: 'Bebas Neue', sans-serif;

    font-size: clamp(36px, 7vw, 58px);

    line-height: 1;

    margin-bottom: 24px;

    letter-spacing: 0.02em;

  }

  .section-body {

    font-size: 16px;

    color: var(--gray);

    line-height: 1.8;

    margin-bottom: 32px;

  }

  /* ── PRIZE CARDS ── */

  .prize-grid {

    display: grid;

    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));

    gap: 16px;

    margin: 40px 0;

  }

  .prize-card {

    background: var(--dark2);

    border: 1px solid var(--border);

    border-top: 2px solid var(--red);

    padding: 28px 24px;

    border-radius: 2px;

    transition: border-color 0.3s, transform 0.3s;

  }

  .prize-card:hover {

    border-color: var(--red);

    transform: translateY(-4px);

  }

  .prize-card-icon {

    font-size: 28px;

    margin-bottom: 14px;

    display: block;

  }

  .prize-card-title {

    font-family: 'Bebas Neue', sans-serif;

    font-size: 22px;

    letter-spacing: 0.05em;

    margin-bottom: 8px;

    color: var(--white);

  }

  .prize-card-desc {

    font-size: 14px;

    color: var(--gray);

    line-height: 1.65;

  }

  /* ── STEPS ── */

  .steps { margin: 40px 0; }

  .step {

    display: flex;

    gap: 24px;

    padding: 28px 0;

    border-bottom: 1px solid var(--border);

    align-items: flex-start;

  }

  .step:last-child { border-bottom: none; }

  .step-num {

    font-family: 'Bebas Neue', sans-serif;

    font-size: 36px;

    color: var(--red);

    line-height: 1;

    min-width: 36px;

    padding-top: 2px;

  }

  .step-content { flex: 1; }

  .step-title {

    font-weight: 600;

    font-size: 18px;

    margin-bottom: 6px;

    color: var(--white);

  }

  .step-desc {

    font-size: 15px;

    color: var(--gray);

    line-height: 1.7;

  }

  .step-desc a {

    color: var(--red-light);

    text-decoration: none;

    border-bottom: 1px solid rgba(231,76,60,0.3);

    transition: border-color 0.2s;

  }

  .step-desc a:hover { border-color: var(--red-light); }

  /* ── T&C PANEL ── */

  .tc-panel {

    background: var(--dark2);

    border: 1px solid var(--border);

    border-radius: 2px;

    overflow: hidden;

    margin: 40px 0;

  }

  .tc-header {

    background: var(--dark3);

    padding: 20px 28px;

    display: flex;

    align-items: center;

    justify-content: space-between;

    gap: 16px;

    border-bottom: 1px solid var(--border);

  }

  .tc-header-left { display: flex; align-items: center; gap: 14px; }

  .tc-icon {

    width: 38px; height: 38px;

    background: rgba(192,57,43,0.15);

    border: 1px solid rgba(192,57,43,0.3);

    border-radius: 50%;

    display: flex; align-items: center; justify-content: center;

    font-size: 16px;

  }

  .tc-doc-name {

    font-weight: 600;

    font-size: 15px;

    color: var(--white);

  }

  .tc-doc-sub {

    font-size: 12px;

    color: var(--gray);

    margin-top: 2px;

  }

  .tc-status {

    font-size: 11px;

    font-weight: 600;

    letter-spacing: 0.15em;

    text-transform: uppercase;

    padding: 5px 12px;

    border-radius: 20px;

    background: rgba(212,168,67,0.12);

    color: var(--gold);

    border: 1px solid rgba(212,168,67,0.25);

    white-space: nowrap;

  }

  .tc-body { padding: 28px; }

  .tc-clauses { margin: 0 0 28px; }

  .tc-clause {

    display: flex;

    gap: 14px;

    padding: 14px 0;

    border-bottom: 1px solid var(--border);

    font-size: 14px;

    color: var(--gray);

    line-height: 1.6;

  }

  .tc-clause:last-child { border-bottom: none; }

  .tc-clause-num {

    color: var(--red);

    font-weight: 600;

    min-width: 20px;

    padding-top: 1px;

  }

  .tc-note {

    background: rgba(212,168,67,0.06);

    border: 1px solid rgba(212,168,67,0.18);

    border-radius: 2px;

    padding: 16px 20px;

    font-size: 13px;

    color: rgba(212,168,67,0.85);

    line-height: 1.65;

    margin-bottom: 24px;

  }

  /* ── BUTTON ── */

  .btn {

    display: inline-flex;

    align-items: center;

    gap: 10px;

    padding: 16px 36px;

    font-family: 'DM Sans', sans-serif;

    font-size: 14px;

    font-weight: 600;

    letter-spacing: 0.08em;

    text-transform: uppercase;

    text-decoration: none;

    border: none;

    cursor: pointer;

    transition: all 0.25s;

    border-radius: 1px;

  }

  .btn-primary {

    background: var(--red);

    color: var(--white);

  }

  .btn-primary:hover {

    background: var(--red-light);

    transform: translateY(-2px);

    box-shadow: 0 12px 40px rgba(192,57,43,0.35);

  }

  .btn-outline {

    background: transparent;

    color: var(--white);

    border: 1px solid rgba(255,255,255,0.2);

  }

  .btn-outline:hover {

    border-color: var(--white);

    transform: translateY(-2px);

  }

  .btn-full { width: 100%; justify-content: center; }

  /* ── CHECKLIST ── */

  .checklist { margin: 28px 0; }

  .check-item {

    display: flex;

    gap: 14px;

    padding: 14px 0;

    border-bottom: 1px solid var(--border);

    align-items: flex-start;

  }

  .check-item:last-child { border-bottom: none; }

  .check-box {

    width: 20px; height: 20px;

    border: 1.5px solid rgba(192,57,43,0.5);

    border-radius: 3px;

    flex-shrink: 0;

    margin-top: 2px;

    display: flex; align-items: center; justify-content: center;

    cursor: pointer;

    transition: background 0.2s, border-color 0.2s;

  }

  .check-box:hover { border-color: var(--red); }

  .check-box.checked { background: var(--red); border-color: var(--red); }

  .check-box svg { display: none; }

  .check-box.checked svg { display: block; }

  .check-label {

    font-size: 15px;

    color: var(--gray-light);

    line-height: 1.6;

  }

  .check-label strong { color: var(--white); font-weight: 600; }

  /* ── APP DOWNLOAD ── */

  .app-box {

    background: var(--dark2);

    border: 1px solid var(--border);

    border-radius: 2px;

    padding: 32px;

    text-align: center;

    margin: 32px 0;

  }

  .app-box-title {

    font-family: 'Bebas Neue', sans-serif;

    font-size: 28px;

    letter-spacing: 0.05em;

    margin-bottom: 8px;

  }

  .app-box-sub {

    font-size: 14px;

    color: var(--gray);

    margin-bottom: 28px;

  }

  .app-btns {

    display: flex;

    gap: 12px;

    justify-content: center;

    flex-wrap: wrap;

  }

  .app-store-btn {

    display: flex;

    align-items: center;

    gap: 10px;

    padding: 14px 24px;

    background: var(--dark3);

    border: 1px solid rgba(255,255,255,0.12);

    border-radius: 2px;

    text-decoration: none;

    color: var(--white);

    transition: all 0.25s;

  }

  .app-store-btn:hover {

    border-color: rgba(255,255,255,0.3);

    transform: translateY(-2px);

  }

  .app-store-btn-label { text-align: left; }

  .app-store-btn-small { font-size: 11px; color: var(--gray); }

  .app-store-btn-name { font-size: 16px; font-weight: 600; }

  /* ── ADAM BLOCK ── */

  .adam-block {

    display: flex;

    gap: 24px;

    align-items: flex-start;

    background: var(--dark2);

    border: 1px solid var(--border);

    border-left: 3px solid var(--red);

    padding: 28px;

    border-radius: 2px;

    margin: 32px 0;

  }

  .adam-avatar {

    width: 56px; height: 56px;

    border-radius: 50%;

    background: var(--red);

    flex-shrink: 0;

    display: flex; align-items: center; justify-content: center;

    font-family: 'Bebas Neue', sans-serif;

    font-size: 22px;

    letter-spacing: 0.05em;

    color: var(--white);

  }

  .adam-name { font-weight: 600; font-size: 15px; color: var(--white); }

  .adam-role { font-size: 12px; color: var(--gray); margin-bottom: 10px; }

  .adam-quote { font-size: 15px; color: var(--gray-light); line-height: 1.7; font-style: italic; }

  /* ── TIMELINE ── */

  .timeline { margin: 32px 0; position: relative; }

  .timeline::before {

    content: '';

    position: absolute;

    left: 14px; top: 8px; bottom: 8px;

    width: 1px;

    background: linear-gradient(to bottom, var(--red), rgba(192,57,43,0.1));

  }

  .tl-item {

    display: flex;

    gap: 24px;

    padding: 0 0 28px;

    position: relative;

  }

  .tl-dot {

    width: 28px; height: 28px;

    border-radius: 50%;

    background: var(--dark);

    border: 1.5px solid var(--red);

    flex-shrink: 0;

    display: flex; align-items: center; justify-content: center;

    font-size: 12px;

    font-weight: 700;

    color: var(--red);

    position: relative;

    z-index: 1;

  }

  .tl-content { padding-top: 4px; flex: 1; }

  .tl-title { font-weight: 600; font-size: 15px; margin-bottom: 4px; }

  .tl-desc { font-size: 14px; color: var(--gray); line-height: 1.65; }

  /* ── FOOTER ── */

  footer {

    border-top: 1px solid var(--border);

    padding: 40px 24px;

    text-align: center;

    font-size: 13px;

    color: var(--gray);

    position: relative;

    z-index: 1;

  }

  footer strong { color: var(--red); }

  /* ── ANIMATIONS ── */

  .fade-up {

    opacity: 0;

    transform: translateY(30px);

    transition: opacity 0.7s ease, transform 0.7s ease;

  }

  .fade-up.visible {

    opacity: 1;

    transform: translateY(0);

  }

  /* ── RESPONSIVE ── */

  @media (max-width: 600px) {

    .adam-block { flex-direction: column; }

    .tc-header { flex-direction: column; align-items: flex-start; }

    .app-btns { flex-direction: column; align-items: center; }

    .step { gap: 16px; }

  }

</style>

</head>

