<script>

  // ── Scroll-triggered fade-in ──

  const observer = new IntersectionObserver((entries) => {

    entries.forEach(e => {

      if (e.isIntersecting) {

        e.target.classList.add('visible');

        observer.unobserve(e.target);

      }

    });

  }, { threshold: 0.12 });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  // ── Checkbox logic ──

  function toggleCheck(box) {

    box.classList.toggle('checked');

    updateSubmitButton();

  }

  function updateSubmitButton() {

    const allChecked = [...document.querySelectorAll('.check-box')].every(b => b.classList.contains('checked'));

    const nameVal = document.getElementById('winner-name').value.trim();

    const btn = document.getElementById('submit-btn');

    const ready = allChecked && nameVal.length > 2;

    btn.disabled = !ready;

    btn.style.opacity = ready ? '1' : '0.4';

    btn.style.cursor = ready ? 'pointer' : 'not-allowed';

  }

  document.getElementById('winner-name').addEventListener('input', updateSubmitButton);

  // ── Submit ──

  function submitAgreement() {

    const btn = document.getElementById('submit-btn');

    const name = document.getElementById('winner-name').value.trim();

    if (!btn || btn.disabled) return;

    btn.style.display = 'none';

    document.getElementById('name-field').style.display = 'none';

    document.getElementById('success-msg').style.display = 'block';

    document.querySelector('.tc-status').textContent = '✓ Signed';

    document.querySelector('.tc-status').style.background = 'rgba(39,174,96,0.12)';

    document.querySelector('.tc-status').style.color = '
#27AE60';

    document.querySelector('.tc-status').style.borderColor = 'rgba(39,174,96,0.25)';

    // In production: POST name + timestamp to a form endpoint (e.g. Formspree, Netlify Forms, or your own backend)

    console.log('Agreement signed by:', name, 'at', new Date().toISOString());

  }

</script>

